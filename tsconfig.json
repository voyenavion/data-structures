{
  "compilerOptions": {
    "target": "ES2022",
    "lib": ["ES2020", "DOM", "DOM.Iterable"],
    "module": "ESNext",
    "skipLibCheck": true,
    "noEmit": false,
    "isolatedModules": true,
    "moduleDetection": "force",
    "outDir": "ts-output",
    "rootDir": "src",
    "checkJs": true,
    "noImplicitAny": false
  },
  "include": ["src"]
}
